# ─────────────────────────────────────────────────────
#  Arabic Medical Chatbot – Environment Configuration
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── LLM Provider ──────────────────────────────────────
# Options: "ollama" | "openrouter"
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=ollama/qwen2.5

# OpenRouter settings (used when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openrouter/qwen/qwen3.5-35b-a3b

# ── Embeddings (AraBERT) ─────────────────────────────
EMBEDDING_MODEL=aubmindlab/bert-base-arabertv2
EMBEDDING_BATCH_SIZE=32
MAX_SEQ_LENGTH=512

# ── Retrieval ─────────────────────────────────────────
TOP_K=5
# Min cosine similarity before falling back to BM25
VECTOR_THRESHOLD=0.50
# Entity boost factor for disease-name matched chunks
ENTITY_BOOST=1.3
# Min relevance threshold for search results
RELEVANCE_THRESHOLD=0.80
# Max characters per retrieved chunk shown in response
MAX_CHUNK_CHARS=600

# ── Data Paths ────────────────────────────────────────
DATA_PATH=data/concatenated_df.csv
FAISS_INDEX_PATH=indexes/faiss_index.bin
BM25_INDEX_PATH=indexes/bm25_index.pkl
METADATA_PATH=indexes/metadata.pkl

# ── Internet Search (Optional) ────────────────────────
ENABLE_SERPER=false
SERPER_API_KEY=your_serper_key_here

# ── MLflow Tracing (Optional) ────────────────────────
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=arabic_medical_chatbot

# ── API Server ────────────────────────────────────────
# Comma-separated API keys for colleague access
API_KEYS=med-api-key-change-me-123
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*
